# Content Engine
OPENROUTER_API_KEY=your_openrouter_api_key
GEMINI_API_KEY=your_gemini_api_key
GSC_KEY_PATH=/path/to/search-console-key.json
DATAFORSEO_LOGIN=your_dataforseo_login
DATAFORSEO_PASSWORD=your_dataforseo_password

# Email notifications
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=beachbride.com
NOTIFY_EMAIL=hello@beachbride.com

# Email list (Sendy)
SENDY_URL=https://your-sendy-instance.com
SENDY_API_KEY=your_sendy_api_key
SENDY_LIST_ID=
SENDY_NURTURE_LIST_ID=

# Payments
STRIPE_SECRET_KEY=

# Worker (local dev via wrangler dev)
# Set Worker secrets via: wrangler secret put <NAME>
