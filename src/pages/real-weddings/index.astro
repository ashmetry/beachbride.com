---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const weddings = await getCollection('realWeddings');
weddings.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const canonical = 'https://beachbride.com/real-weddings/';
---

<BaseLayout
  title="Real Beach Weddings — Inspiration & Ideas | BeachBride"
  description="Browse real beach and destination weddings for inspiration. See actual couples, venues, and styles from around the world."
  canonical={canonical}
  ogImage="/images/logo.png"
>
  <main class="max-w-6xl mx-auto px-4 py-10">

    <header class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Real Beach Weddings</h1>
      <p class="text-gray-600 max-w-xl mx-auto">
        Real couples. Real venues. Real inspiration. Browse {weddings.length} beach and destination weddings from around the world.
      </p>
    </header>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {weddings.map(w => (
        <a
          href={`/real-weddings/${w.id.replace(/\.mdx?$/, '')}/`}
          class="group block rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-shadow bg-white"
        >
          {w.data.heroImage ? (
            <div class="aspect-[4/3] overflow-hidden bg-gray-100">
              <img
                src={w.data.heroImage}
                alt={w.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          ) : (
            <div class="aspect-[4/3] bg-brand-light flex items-center justify-center">
              <span class="text-4xl">🌊</span>
            </div>
          )}
          <div class="p-4">
            <h2 class="font-semibold text-gray-900 text-sm leading-snug group-hover:text-brand transition-colors line-clamp-2">
              {w.data.title}
            </h2>
            {w.data.location && (
              <p class="text-xs text-gray-400 mt-1">📍 {w.data.location}</p>
            )}
            {w.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-2">
                {w.data.tags.slice(0, 3).map(tag => (
                  <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-14 bg-brand-light border border-brand/20 rounded-xl p-8 text-center">
      <p class="text-xl font-semibold text-gray-800 mb-2">Ready to plan your own beach wedding?</p>
      <p class="text-gray-600 mb-5">Answer 3 quick questions and get a free personalized destination guide.</p>
      <a
        href="/quiz/"
        class="inline-block bg-brand text-white font-semibold px-8 py-3 rounded-lg hover:bg-brand-dark transition-colors"
      >
        Get My Free Guide →
      </a>
    </div>

  </main>
</BaseLayout>
