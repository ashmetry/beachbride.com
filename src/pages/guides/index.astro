---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { GUIDE_CATEGORIES, getCategoryForSlug } from '../../data/guide-categories';

const allArticles = await getCollection('articles', a => !a.data.noIndex);

// Group articles by category and get the most recent 3 per category for preview
const categorized = GUIDE_CATEGORIES.map(cat => {
  const articles = allArticles
    .filter(a => getCategoryForSlug(a.id.replace(/\.mdx?$/, '')).slug === cat.slug)
    .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
  return { cat, articles, preview: articles.slice(0, 3) };
});

const totalArticles = allArticles.length;
const canonical = 'https://beachbride.com/guides/';
---

<BaseLayout
  title="Beach & Destination Wedding Guides | BeachBride"
  description="Expert planning guides, décor ideas, food menus, bridal style, and destination deep-dives for your perfect beach wedding."
  canonical={canonical}
  ogImage="/images/logo.png"
>
  <main class="max-w-6xl mx-auto px-4 py-10">

    <header class="text-center mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Wedding Guides</h1>
      <p class="text-gray-600 max-w-xl mx-auto">
        {totalArticles} expert guides covering everything from budgeting to bridal style — all written for beach and destination weddings.
      </p>
    </header>

    <!-- Category sections -->
    {categorized.map(({ cat, articles, preview }) => (
      <section class="mb-14">

        <!-- Category header -->
        <div class="flex items-center justify-between mb-5">
          <div class="flex items-center gap-2">
            <div>
              <h2 class="text-xl font-bold text-gray-900">{cat.label}</h2>
              <p class="text-sm text-gray-500">{articles.length} {articles.length === 1 ? 'guide' : 'guides'}</p>
            </div>
          </div>
          {articles.length > 3 && (
            <a href={`/guides/${cat.slug}/`} class="text-sm font-medium text-brand hover:text-brand-dark no-underline">
              See all {articles.length} →
            </a>
          )}
        </div>

        <!-- Preview cards -->
        {preview.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {preview.map(article => {
              const slug = article.id.replace(/\.mdx?$/, '');
              return (
                <a
                  href={`/${slug}/`}
                  class="group block rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-shadow bg-white"
                >
                  {article.data.heroImage ? (
                    <div class="aspect-[16/9] overflow-hidden bg-gray-100">
                      <img
                        src={article.data.heroImage}
                        alt={article.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="aspect-[16/9] bg-brand-light"></div>
                  )}
                  <div class="p-4">
                    <h3 class="font-semibold text-gray-900 text-sm leading-snug group-hover:text-brand transition-colors line-clamp-2">
                      {article.data.title}
                    </h3>
                    <p class="text-xs text-gray-500 mt-1.5 line-clamp-2">{article.data.description}</p>
                  </div>
                </a>
              );
            })}

            {/* "See all" card if more than 3 */}
            {articles.length > 3 && (
              <a
                href={`/guides/${cat.slug}/`}
                class="group flex flex-col items-center justify-center rounded-xl border-2 border-dashed border-gray-200 hover:border-brand hover:bg-brand-light transition-colors p-6 text-center min-h-[180px]"
              >
                <span class="text-sm font-semibold text-gray-600 group-hover:text-brand">
                  +{articles.length - 3} more {cat.label} guides
                </span>
                <span class="text-xs text-gray-400 mt-1">See all →</span>
              </a>
            )}
          </div>
        ) : (
          <p class="text-sm text-gray-400 italic">Coming soon.</p>
        )}

      </section>
    ))}

    <!-- CTA -->
    <div class="bg-brand-light border border-brand/20 rounded-xl p-8 text-center">
      <p class="text-xl font-semibold text-gray-800 mb-2">Ready to start planning?</p>
      <p class="text-gray-600 mb-5">Answer 3 quick questions and get a free personalized destination guide.</p>
      <a href="/quiz/" class="inline-block bg-brand text-white font-semibold px-8 py-3 rounded-lg hover:bg-brand-dark transition-colors">
        Get My Free Guide →
      </a>
    </div>

  </main>
</BaseLayout>
