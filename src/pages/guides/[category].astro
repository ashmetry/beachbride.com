---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { GUIDE_CATEGORIES, getCategoryForSlug } from '../../data/guide-categories';

export async function getStaticPaths() {
  return GUIDE_CATEGORIES.map(cat => ({
    params: { category: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;

const allArticles = await getCollection('articles', a => !a.data.noIndex);
const articles = allArticles
  .filter(a => getCategoryForSlug(a.id.replace(/\.mdx?$/, '')).slug === cat.slug)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const canonical = `https://beachbride.com/guides/${cat.slug}/`;

// Breadcrumb trail for other categories
const otherCats = GUIDE_CATEGORIES.filter(c => c.slug !== cat.slug);
---

<BaseLayout
  title={`${cat.label} — Beach Wedding Guides | BeachBride`}
  description={cat.description}
  canonical={canonical}
  ogImage="/images/logo.png"
>
  <main class="max-w-6xl mx-auto px-4 py-10">

    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-brand">Home</a>
      <span class="mx-2">›</span>
      <a href="/guides/" class="hover:text-brand">Guides</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">{cat.label}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-3 mb-2">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900">{cat.label}</h1>
      </div>
      <p class="text-gray-600 max-w-2xl">{cat.description}</p>
      <p class="text-sm text-gray-400 mt-2">{articles.length} {articles.length === 1 ? 'guide' : 'guides'}</p>
    </header>

    <!-- Article grid -->
    {articles.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-14">
        {articles.map(article => {
          const slug = article.id.replace(/\.mdx?$/, '');
          return (
            <a
              href={`/${slug}/`}
              class="group block rounded-xl overflow-hidden border border-gray-100 shadow-sm hover:shadow-md transition-shadow bg-white"
            >
              {article.data.heroImage ? (
                <div class="aspect-[16/9] overflow-hidden bg-gray-100">
                  <img
                    src={article.data.heroImage}
                    alt={article.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              ) : (
                <div class="aspect-[16/9] bg-brand-light"></div>
              )}
              <div class="p-4">
                <h2 class="font-semibold text-gray-900 text-sm leading-snug group-hover:text-brand transition-colors line-clamp-2">
                  {article.data.title}
                </h2>
                <p class="text-xs text-gray-500 mt-1.5 line-clamp-2">{article.data.description}</p>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <p class="text-gray-500 mb-14">No guides in this category yet — check back soon.</p>
    )}

    <!-- Other categories -->
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-gray-800 mb-4">Browse other categories</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {otherCats.map(c => (
          <a
            href={`/guides/${c.slug}/`}
            class="flex items-center gap-2 p-3 rounded-lg border border-gray-200 hover:border-brand hover:bg-brand-light transition-colors no-underline text-sm font-medium text-gray-700 hover:text-brand"
          >
            <span>{c.label}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <div class="bg-brand-light border border-brand/20 rounded-xl p-8 text-center">
      <p class="text-xl font-semibold text-gray-800 mb-2">Ready to start planning?</p>
      <p class="text-gray-600 mb-5">Answer 3 quick questions and get a free personalized destination guide.</p>
      <a href="/quiz/" class="inline-block bg-brand text-white font-semibold px-8 py-3 rounded-lg hover:bg-brand-dark transition-colors">
        Get My Free Guide →
      </a>
    </div>

  </main>
</BaseLayout>
