---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import WeatherRiskBar from '../../components/destination/WeatherRiskBar.astro';
import GuestBurdenScore from '../../components/destination/GuestBurdenScore.astro';
import CeremonyTypeBadge from '../../components/destination/CeremonyTypeBadge.astro';
import MicroDestinations from '../../components/destination/MicroDestinations.astro';
import destinations from '../../data/destinations.json';
import vendors from '../../data/vendors.json';
import { getDestinationSchema } from '../../lib/schema/destination';
import { SITE_CONFIG } from '../../lib/site-config';
import { affiliateLinks } from '../../data/affiliate-links';
import { VENDOR_TYPES, typePluralLabels, type VendorType } from '../../lib/vendors';
import { getCollection } from 'astro:content';
import { existsSync } from 'fs';
import { join } from 'path';

export async function getStaticPaths() {
  return destinations.map(d => ({ params: { destination: d.slug } }));
}

const { destination: slug } = Astro.params;
const dest = destinations.find(d => d.slug === slug)!;

// Vendors for this destination — only claimed, lead-eligible vendors shown to couples
const LEAD_TYPES = ['planner', 'photographer', 'florist', 'caterer', 'dj', 'officiant'];
const localVendors = vendors.filter(
  v => v.destinations.includes(slug) && LEAD_TYPES.includes(v.type) && v.claimed === true
).slice(0, 6);

// Articles tagged to this destination
const allArticles = await getCollection('articles').catch(() => []);
const destArticles = allArticles
  .filter(a => a.data.destination === slug && !a.data.noIndex)
  .slice(0, 3);

// Affiliate link keys for this destination (fall back to generic if no deep link)
const bookingKey = affiliateLinks[`booking-${slug}`] ? `booking-${slug}` : 'booking';
const gygKey = affiliateLinks[`getyourguide-${slug}`] ? `getyourguide-${slug}` : 'getyourguide';

const heroExists = dest.heroImage && existsSync(join('public', dest.heroImage));
const schema = getDestinationSchema(dest);
const canonical = `https://beachbride.com/destinations/${slug}/`;

// Guest burden score color
const guestScoreColor = dest.guestBurden.score >= 8 ? 'text-green-600' : dest.guestBurden.score >= 5 ? 'text-yellow-600' : 'text-red-500';

// Legal ceremony display
const legalDisplay = dest.legalCeremonyType === 'legal' ? 'Yes — legal' :
  dest.legalCeremonyType === 'symbolic-recommended' ? 'Symbolic rec.' :
  'Symbolic only';
---

<BaseLayout
  title={`${dest.name} Destination Wedding Guide — Costs, Venues & Vendors`}
  description={`Plan your dream ${dest.name} wedding. Complete guide: average costs $${(dest.avgCostUSD.min/1000).toFixed(0)}k–$${(dest.avgCostUSD.max/1000).toFixed(0)}k, best resorts, vetted vendors, legal requirements, and best time to visit.`}
  canonical={canonical}
  schema={schema}
>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-10">
    <Breadcrumb crumbs={[
      { label: 'Destinations', href: '/destinations/' },
      { label: dest.name },
    ]} />

    <!-- Hero -->
    {heroExists ? (
      <div class="relative mb-8">
        <img
          src={dest.heroImage}
          alt={`${dest.name} destination wedding`}
          class="w-full rounded-2xl object-cover aspect-[21/9]"
          loading="eager"
        />
        {dest.isHiddenGem && (
          <span class="absolute top-4 right-4 bg-brand-accent/90 text-white text-xs font-semibold px-3 py-1 rounded-full backdrop-blur-sm">
            ✦ Hidden Gem
          </span>
        )}
      </div>
    ) : (
      <div class="relative w-full rounded-2xl bg-brand-light aspect-[21/9] mb-8">
        {dest.isHiddenGem && (
          <span class="absolute top-4 right-4 bg-brand-accent/90 text-white text-xs font-semibold px-3 py-1 rounded-full">
            ✦ Hidden Gem
          </span>
        )}
      </div>
    )}

    <div class="flex items-center gap-3 mb-2">
      <div>
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900">{dest.name} Destination Wedding</h1>
        <p class="text-gray-500">{dest.country} &middot; {dest.region}</p>
      </div>
    </div>
    <p class="text-lg text-gray-600 mt-4 mb-4">{dest.description}</p>
    <p class="text-xs text-gray-400 bg-gray-50 rounded-lg px-4 py-2 mb-8 not-prose">This guide contains affiliate links. BeachBride may earn a commission at no extra cost to you.</p>

    <!-- Quick stats -->
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-4 mb-10">
      <div class="bg-white rounded-xl p-4 border border-gray-100 text-center">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Avg Cost</p>
        <p class="font-bold text-gray-900">${(dest.avgCostUSD.min/1000).toFixed(0)}k–${(dest.avgCostUSD.max/1000).toFixed(0)}k</p>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-100 text-center">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Best Season</p>
        <p class="font-bold text-gray-900">{dest.bestMonths.slice(0,2).join(' – ')}</p>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-100 text-center">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Visa Required</p>
        <p class="font-bold text-gray-900">{dest.visaRequired ? 'Yes' : 'Usually No'}</p>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-100 text-center">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Legal Wedding</p>
        <p class="font-bold text-gray-900">{legalDisplay}</p>
      </div>
      <div class="bg-white rounded-xl p-4 border border-gray-100 text-center">
        <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Guest Score</p>
        <p class={`font-bold ${guestScoreColor}`}>{dest.guestBurden.score}/10</p>
      </div>
    </div>

    <!-- Weather Risk -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Best time to get married in {dest.name}</h2>
      <WeatherRiskBar
        monthlyWeather={dest.monthlyWeather}
        bestMonths={dest.bestMonths}
        destinationName={dest.name}
      />
      {dest.climateDataSource && (
        <p class="text-xs text-gray-400 mt-2">
          Weather data: {dest.climateDataSource}. Hurricane risk: NOAA historical data.
          {dest.climateDataUpdated && ` Last updated: ${dest.climateDataUpdated}.`}
        </p>
      )}
    </section>

    <!-- Guest Burden Score -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">What it costs your guests</h2>
      <GuestBurdenScore
        guestBurden={dest.guestBurden}
        destinationName={dest.name}
      />
    </section>

    <!-- Legal / Ceremony Type -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-3">Legal requirements</h2>
      <CeremonyTypeBadge
        legalCeremonyType={dest.legalCeremonyType}
        legalNotes={dest.legalNotes}
        destinationName={dest.name}
      />
    </section>

    <!-- Micro-Destinations -->
    <MicroDestinations
      microDestinations={dest.microDestinations}
      destinationName={dest.name}
    />

    <!-- Wedding Resorts (Tracked Affiliate) -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">Top resorts for {dest.name} weddings</h2>
      <p class="text-gray-600 text-sm mb-4">
        Comparing resorts is the biggest early decision. We filter for 4-5 star properties rated 8.0+ by verified guests — the kind of places that actually host weddings well.
      </p>
      <div class="affiliate-card not-prose">
        <div class="affiliate-card-inner">
          <span class="affiliate-card-label">We Recommend</span>
          <p class="affiliate-card-title">Luxury Wedding Resorts in {dest.name}</p>
          <p class="affiliate-card-desc">4-5 star resorts rated 8.0+ by verified guests. Filter by all-inclusive, beachfront, wedding-friendly amenities, and free cancellation.</p>
          <p class="affiliate-card-proof">Free cancellation on most properties. No booking fees.</p>
          <a class="affiliate-card-cta" href={`/go/${bookingKey}`} target="_blank" rel="sponsored nofollow noopener">
            Search {dest.name} Resorts
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Guest Accommodations / Room Block -->
    <section class="mb-10">
      <div class="bg-brand-light border border-brand/20 rounded-2xl p-6 flex flex-col sm:flex-row items-start gap-5">
        <div class="flex-shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-brand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Zm0 3h.008v.008h-.008v-.008Z" />
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-bold text-gray-900 mb-1">Where will your guests stay?</h3>
          <p class="text-sm text-gray-600 mb-3">
            Most {dest.name} couples have 20–50 guests traveling. We secure a group rate at the resort of your choice —
            locked-in pricing, a private booking link for guests, and complimentary perks based on your room count.
            Free to you — the resort covers our fee.
          </p>
          <div class="flex flex-wrap gap-4 mb-3">
            <span class="text-xs text-gray-500 flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Group rate locked for your guests
            </span>
            <span class="text-xs text-gray-500 flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Complimentary rooms at thresholds
            </span>
            <span class="text-xs text-gray-500 flex items-center gap-1">
              <svg class="w-3.5 h-3.5 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              One contact for all guest questions
            </span>
          </div>
          <div class="flex flex-wrap gap-3">
            <a
              href="/tools/room-block-calculator/"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand hover:underline no-underline"
            >
              Estimate your room block
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <span class="text-gray-300">|</span>
            <a
              href={SITE_CONFIG.roomBlockCalendlyUrl || `mailto:hello@beachbride.com?subject=Room%20Block%20Inquiry%20%E2%80%94%20${encodeURIComponent(dest.name)}&body=Hi%2C%20I'm%20planning%20a%20destination%20wedding%20in%20${encodeURIComponent(dest.name)}%20and%20would%20like%20help%20with%20a%20group%20rate.`}
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-gray-600 hover:text-brand transition-colors no-underline"
            >
              Get a free group rate quote
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Travel Insurance -->
    <section class="mb-10">
      <div class="affiliate-card not-prose">
        <div class="affiliate-card-inner">
          <span class="affiliate-card-label">We Recommend</span>
          <p class="affiliate-card-title">Trip Protection for Your Wedding Party</p>
          <p class="affiliate-card-desc">International flights, non-refundable deposits, and tropical weather all carry real risk. Cover your entire guest list with cancel-for-any-reason options designed for destination weddings.</p>
          <p class="affiliate-card-proof">A+ rated insurer. Group plans available for wedding parties.</p>
          <a class="affiliate-card-cta" href="/go/generali" target="_blank" rel="sponsored nofollow noopener">
            Compare Plans
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Destination Photographer -->
    <section class="mb-10">
      <div class="affiliate-card not-prose">
        <div class="affiliate-card-inner">
          <span class="affiliate-card-label">We Recommend</span>
          <p class="affiliate-card-title">Book a Local Photographer in {dest.name}</p>
          <p class="affiliate-card-desc">Professional photographers who know {dest.name}'s best light, angles, and hidden spots. They handle permits, backup plans for weather, and deliver within weeks.</p>
          <p class="affiliate-card-proof">3 million+ photos taken. 100% happiness guarantee.</p>
          <a class="affiliate-card-cta" href="/go/flytographer-wedding" target="_blank" rel="sponsored nofollow noopener">
            Find a Photographer
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Local Vendors -->
    {localVendors.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Vetted vendors in {dest.name}</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {localVendors.map(v => (
            <a href={`/vendors/${v.slug}/`} class="card p-4 hover:shadow-md transition-shadow no-underline group flex items-start gap-3">
              <div class="w-10 h-10 rounded-lg bg-brand-light flex items-center justify-center flex-shrink-0 text-xs font-bold text-brand uppercase">
                {v.type.slice(0, 2)}
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 group-hover:text-brand transition-colors text-sm">{v.name}</h3>
                <p class="text-xs text-gray-400 capitalize">{v.type} &middot; {dest.name}</p>
                {v.rating && (
                  <p class="text-xs text-gray-500 mt-0.5">★ {v.rating} ({v.reviewCount} reviews)</p>
                )}
              </div>
            </a>
          ))}
        </div>
        <div class="mt-4">
          <a href={`/vendors/${slug}/`} class="text-brand text-sm font-medium hover:underline no-underline">
            View all {dest.name} vendors →
          </a>
        </div>
      </section>
    )}

    <!-- Find vendors by type -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Find {dest.name} wedding vendors</h2>
      <div class="flex flex-wrap gap-2">
        {(['planner', 'photographer', 'florist', 'caterer', 'dj', 'officiant'] as const).filter(t =>
          vendors.some((v: any) => v.type === t && v.destinations.includes(slug))
        ).map(t => {
          const count = vendors.filter((v: any) => v.type === t && v.destinations.includes(slug)).length;
          return (
            <a
              href={`/vendors/${t}/${slug}/`}
              class="flex items-center gap-1.5 px-4 py-2 border border-gray-200 rounded-full text-sm font-medium text-gray-700 hover:border-brand hover:text-brand transition-colors no-underline"
            >
              {typePluralLabels[t as VendorType]}
              <span class="text-xs text-gray-400">({count})</span>
            </a>
          );
        })}
        <a
          href={`/vendors/${slug}/`}
          class="px-4 py-2 border border-gray-200 rounded-full text-sm font-medium text-gray-700 hover:border-brand hover:text-brand transition-colors no-underline"
        >
          All vendors →
        </a>
      </div>
    </section>

    <!-- Guest Activities -->
    <section class="mb-10">
      <div class="affiliate-card not-prose">
        <div class="affiliate-card-inner">
          <span class="affiliate-card-label">We Recommend</span>
          <p class="affiliate-card-title">Wedding-Week Activities in {dest.name}</p>
          <p class="affiliate-card-desc">Snorkeling, sunset cruises, food tours, and more. Book group activities your guests will actually remember — with free cancellation up to 24 hours before.</p>
          <p class="affiliate-card-proof">Free cancellation up to 24 hours before. Mobile tickets.</p>
          <a class="affiliate-card-cta" href={`/go/${gygKey}`} target="_blank" rel="sponsored nofollow noopener">
            Browse {dest.name} Activities
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Related articles -->
    {destArticles.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">{dest.name} wedding guides</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          {destArticles.map(a => (
            <a href={`/${a.slug}/`} class="card p-4 hover:shadow-md transition-shadow no-underline group">
              <p class="font-semibold text-sm text-gray-900 group-hover:text-brand transition-colors">{a.data.title}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- CTA -->
    <div class="lead-capture-box not-prose">
      <h2 class="text-xl font-bold text-gray-900 mb-2">Ready to plan your {dest.name} wedding?</h2>
      <p class="text-sm text-gray-600 mb-4">
        Get a personalized guide with resort picks, costs, and a planning timeline — delivered instantly, free.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/quiz/" class="btn-primary">Get my free guide →</a>
        <a href="/quiz/?stage=2" class="btn-outline">Find a planner</a>
      </div>
    </div>
  </main>
</BaseLayout>
