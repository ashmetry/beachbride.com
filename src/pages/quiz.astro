---
import BaseLayout from '../layouts/BaseLayout.astro';
import DestinationQuiz from '../components/quiz/DestinationQuiz';
import LeadQuiz from '../components/quiz/LeadQuiz';
import { getOrganizationSchema } from '../lib/schema/organization';
import { SITE_CONFIG } from '../lib/site-config';

// ?stage=2 renders the full lead capture quiz
const stage = Astro.url.searchParams.get('stage') ?? '1';
const isStage2 = stage === '2';
const turnstileKey = SITE_CONFIG.turnstileSiteKey;

const schema = getOrganizationSchema();
---

<BaseLayout
  title={isStage2
    ? 'Get Matched with Wedding Vendors — BeachBride'
    : 'Find Your Dream Destination — Free Wedding Guide'}
  description={isStage2
    ? 'Tell us about your destination wedding and we\'ll match you with vetted planners, photographers, and more — free.'
    : 'Answer 3 quick questions and get a personalized destination wedding guide delivered to your inbox. Free, instant, no spam.'}
  canonical="https://beachbride.com/quiz/"
  schema={schema}
>
  <main class="max-w-xl mx-auto px-4 sm:px-6 py-10">
    {!isStage2 && (
      <div class="text-center mb-8">
        <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-2">Free Destination Guide</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">
          Where will you say<br />"I do"?
        </h1>
        <p class="text-gray-500">4 quick questions &middot; Your top 3 matches delivered instantly &middot; No spam</p>
      </div>
    )}

    {isStage2 && (
      <div class="text-center mb-8">
        <p class="text-brand-accent font-semibold text-sm uppercase tracking-widest mb-2">Vendor Matching</p>
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">
          Let's find your<br />perfect team
        </h1>
        <p class="text-gray-500">Tell us about your wedding and we'll match you with vetted local vendors — free.</p>
      </div>
    )}

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sm:p-8">
      {!isStage2
        ? <DestinationQuiz client:load turnstileSiteKey={turnstileKey} />
        : <LeadQuiz client:load turnstileSiteKey={turnstileKey} />
      }
    </div>

    <div class="mt-8 grid sm:grid-cols-3 gap-4 text-sm text-gray-500">
      <div class="flex items-start gap-2">
        <span class="text-brand font-bold mt-0.5">✓</span>
        <span>Free — no account needed</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-brand font-bold mt-0.5">✓</span>
        <span>Vetted vendors only</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-brand font-bold mt-0.5">✓</span>
        <span>No obligation — just guidance</span>
      </div>
    </div>
  </main>

  {turnstileKey && <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}

  <style is:global>
    /* Quiz shared styles — used by both DestinationQuiz and LeadQuiz */
    .quiz-option-card {
      position: relative;
      display: flex; flex-direction: column; align-items: center;
      padding: 0.875rem; gap: 0.25rem;
      border: 2px solid #e5e7eb; border-radius: 0.75rem;
      background: white; cursor: pointer; text-align: center;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .quiz-option-card:hover,
    .quiz-option-card.selected {
      border-color: #1C2B4A;
      box-shadow: 0 0 0 3px rgba(28,43,74,0.1);
    }

    .quiz-list-option {
      width: 100%; text-align: left;
      padding: 0.75rem 1rem;
      border: 2px solid #e5e7eb; border-radius: 0.5rem;
      background: white; cursor: pointer; font-size: 0.9375rem; color: #111827;
      transition: border-color 0.15s;
    }
    .quiz-list-option:hover,
    .quiz-list-option.selected { border-color: #1C2B4A; background: #E8ECF4; }

    .quiz-chip {
      padding: 0.5rem 0.75rem;
      border: 2px solid #e5e7eb; border-radius: 9999px;
      background: white; cursor: pointer; font-size: 0.8125rem; color: #374151;
      transition: border-color 0.15s, background 0.15s;
    }
    .quiz-chip:hover,
    .quiz-chip.selected { border-color: #1C2B4A; background: #E8ECF4; color: #111B30; font-weight: 600; }

    .quiz-input {
      width: 100%; padding: 0.625rem 0.875rem;
      border: 1.5px solid #d1d5db; border-radius: 0.5rem;
      font-size: 1rem; color: #111827;
      transition: border-color 0.15s;
    }
    .quiz-input:focus { outline: none; border-color: #1C2B4A; box-shadow: 0 0 0 3px rgba(28,43,74,0.1); }

    .quiz-label {
      display: block; font-size: 0.875rem; font-weight: 600; color: #374151; margin-bottom: 0.375rem;
    }

    .quiz-btn-primary {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 0.75rem 1.5rem;
      background: #C9974A; color: white;
      border: none; border-radius: 0.75rem; font-size: 1rem; font-weight: 700;
      cursor: pointer; text-decoration: none; transition: background 0.15s;
    }
    .quiz-btn-primary:hover { background: #A67A35; }
    .quiz-btn-primary:disabled { opacity: 0.7; cursor: not-allowed; }

    .quiz-btn-outline {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 0.75rem 1.5rem;
      border: 2px solid #1C2B4A; color: #1C2B4A;
      border-radius: 0.75rem; font-size: 1rem; font-weight: 600;
      cursor: pointer; text-decoration: none; background: white; transition: all 0.15s;
    }
    .quiz-btn-outline:hover { background: #1C2B4A; color: white; }

    .quiz-submit-btn {
      width: 100%; padding: 0.875rem;
      background: #C9974A; color: white;
      border: none; border-radius: 0.75rem; font-size: 1rem; font-weight: 700;
      cursor: pointer; transition: background 0.15s;
    }
    .quiz-submit-btn:hover:not(:disabled) { background: #A67A35; }
    .quiz-submit-btn:disabled { opacity: 0.7; cursor: not-allowed; }

    .quiz-back-btn {
      background: none; border: none; color: #6b7280; font-size: 0.875rem;
      cursor: pointer; padding: 0; display: block;
    }
    .quiz-back-btn:hover { color: #374151; }

    .quiz-match-card {
      position: relative;
      display: flex; flex-direction: column; align-items: center;
      padding: 1.25rem 1rem;
      border: 2px solid #e5e7eb; border-radius: 0.75rem;
      background: white; text-decoration: none; text-align: center;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .quiz-match-card:hover {
      border-color: #1C2B4A;
      box-shadow: 0 4px 12px rgba(28,43,74,0.15);
    }
  </style>
</BaseLayout>
