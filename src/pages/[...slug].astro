---
import { getCollection } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import { getOrganizationSchema, getWebSiteSchema } from '../lib/schema/organization';
import { getArticleSchema } from '../lib/schema/article';
import { getHowToSchema } from '../lib/schema/howto';
import { getFaqSchema } from '../lib/schema/faq';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

const canonicalUrl = `https://beachbride.com/${entry.slug}/`;

const schemas: Record<string, unknown>[] = [
  getOrganizationSchema(),
  getWebSiteSchema(),
  getArticleSchema(entry.data, canonicalUrl),
];

if (entry.data.schemaType === 'howto' && entry.data.howToSteps?.length) {
  schemas.push(getHowToSchema(entry.data as Parameters<typeof getHowToSchema>[0], canonicalUrl));
}

if (entry.data.faqs?.length) {
  schemas.push(getFaqSchema(entry.data.faqs));
}
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={canonicalUrl}
  schema={schemas}
  ogImage={entry.data.heroImage ? `https://beachbride.com${entry.data.heroImage}` : undefined}
  headings={headings}
  frontmatter={entry.data}
  slug={entry.slug}
  rawContent={entry.body}
>
  <Content />
</ArticleLayout>
