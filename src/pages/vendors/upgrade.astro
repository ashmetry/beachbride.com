---
import PageLayout from '../../layouts/PageLayout.astro';
import VendorSignupForm from '../../components/forms/VendorSignupForm.astro';
---

<PageLayout
  title="List Your Business — BeachBride Vendor Directory"
  description="Join BeachBride's vetted vendor network. Connect with couples planning destination weddings in Cancun, Bali, Santorini, Hawaii, and more."
  canonical="https://beachbride.com/vendors/upgrade/"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-3">List your business</h1>
  <p class="text-gray-600 mb-8">
    BeachBride connects vetted wedding professionals with couples planning destination weddings worldwide.
    Join our network of planners, photographers, florists, caterers, DJs, and officiants.
  </p>

  <!-- Pricing tiers -->
  <div class="grid sm:grid-cols-3 gap-4 mb-10">
    {[
      {
        name: 'Free',
        price: '$0',
        period: 'forever',
        features: ['Basic directory listing', '1 destination', 'Profile page', 'Contact form'],
        highlight: false,
      },
      {
        name: 'Premium',
        price: '$99',
        period: 'per month',
        features: ['Featured placement', 'Verified badge', '3 destinations', 'Lead alerts', 'Priority in search'],
        highlight: true,
      },
      {
        name: 'Pro',
        price: '$199',
        period: 'per month',
        features: ['All destinations', 'Priority matching', 'Branded profile', 'Direct inquiry button', 'Analytics dashboard'],
        highlight: false,
      },
    ].map(tier => (
      <div class={`rounded-xl p-5 border-2 ${tier.highlight ? 'border-brand bg-brand-light' : 'border-gray-200 bg-white'}`}>
        <p class="font-bold text-gray-900">{tier.name}</p>
        <p class={`text-2xl font-bold mt-1 ${tier.highlight ? 'text-brand' : 'text-gray-900'}`}>
          {tier.price}
          <span class="text-sm font-normal text-gray-500"> /{tier.period}</span>
        </p>
        <ul class="mt-4 space-y-1.5">
          {tier.features.map(f => (
            <li class="text-sm text-gray-600 flex items-center gap-2">
              <span class={`font-bold ${tier.highlight ? 'text-brand' : 'text-gray-400'}`}>✓</span>
              {f}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="border-t border-gray-200 pt-8">
    <h2 class="text-xl font-bold text-gray-900 mb-2">Apply to join</h2>
    <p class="text-sm text-gray-500 mb-6">
      We review all applications and follow up within 2 business days. Free listings are approved immediately.
      Premium and Pro listings include a brief portfolio review.
    </p>
    <VendorSignupForm />
  </div>
</PageLayout>
