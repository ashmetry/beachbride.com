---
import PageLayout from '../../layouts/PageLayout.astro';
import VendorSignupForm from '../../components/forms/VendorSignupForm.astro';
import vendors from '../../data/vendors.json';

const claimSlug = Astro.url.searchParams.get('claim') ?? '';
const claimedVendor = claimSlug ? vendors.find(v => v.slug === claimSlug) : null;
---

<PageLayout
  title={claimedVendor ? `Claim ${claimedVendor.name} — BeachBride` : 'List Your Business Free — BeachBride'}
  description="List your destination wedding business on BeachBride for free. No cost, no commitment. We connect you with couples actively planning."
  canonical="https://beachbride.com/vendors/upgrade/"
>

  {claimedVendor && (
    <div class="bg-brand-light border border-brand/20 rounded-xl p-5 mb-8 flex items-start gap-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      <p class="text-sm text-gray-700">
        <strong>{claimedVendor.name}</strong> is already listed on BeachBride.
        Fill in your details below and we'll activate your profile within 1 business day.
      </p>
    </div>
  )}

  <h1 class="text-3xl font-bold text-gray-900 mb-3">
    {claimedVendor ? 'Claim your listing — it\'s free' : 'List your business — it\'s free'}
  </h1>

  <p class="text-gray-600 mb-6 text-base leading-relaxed">
    When a couple planning a destination wedding matches your location and specialty, we'll
    send you their details. No monthly fee, no lead charges, no catch.
  </p>

  <!-- Why it's free -->
  <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 mb-10">
    <p class="text-sm font-semibold text-gray-800 mb-2">Why is it free?</p>
    <p class="text-sm text-gray-600 leading-relaxed">
      We make money the same way a travel magazine does — through affiliate commissions
      when couples book resorts, purchase wedding rings, or buy travel insurance through
      our guides. Vendors are how we deliver on our promise to couples. Getting you in
      front of the right people is the whole point.
    </p>
  </div>

  <VendorSignupForm prefillName={claimedVendor?.name ?? ''} />

</PageLayout>
