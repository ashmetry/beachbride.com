---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import VendorTypeIcon from '../../components/vendors/VendorTypeIcon.astro';
import vendors from '../../data/vendors.json';
import destinations from '../../data/destinations.json';
import { getVendorSchema } from '../../lib/schema/localBusiness';
import {
  LEAD_TYPES, typeLabels, typePluralLabels, type VendorType,
} from '../../lib/vendors';

export async function getStaticPaths() {
  return vendors.map(v => ({ params: { slug: v.slug }, props: { vendor: v } }));
}

const { vendor } = Astro.props;

const isLeadVendor = LEAD_TYPES.includes(vendor.type as VendorType);
const isClaimed = vendor.claimed === true;

const vendorDestinations = destinations.filter(d => vendor.destinations.includes(d.slug));
const schema = getVendorSchema({
  name: vendor.name,
  description: vendor.description,
  slug: vendor.slug,
  type: vendor.type,
  destination: vendorDestinations[0]?.name,
  website: vendor.website || undefined,
  phone: vendor.contact?.phone || undefined,
  rating: vendor.rating,
  reviewCount: vendor.reviewCount,
});

const claimUrl = `/vendors/upgrade/?claim=${vendor.slug}`;
---

<BaseLayout
  title={`${vendor.name} — ${typeLabels[vendor.type] ?? vendor.type} | BeachBride`}
  description={vendor.description}
  canonical={`https://beachbride.com/vendors/${vendor.slug}/`}
  schema={schema}
>
  <main class="max-w-4xl mx-auto px-4 sm:px-6 py-10">
    <Breadcrumb crumbs={[
      { label: 'Vendors', href: '/vendors/' },
      { label: typePluralLabels[vendor.type as VendorType] ?? vendor.type, href: `/vendors/${vendor.type}/` },
      { label: vendor.name },
    ]} />

    <div class={`card p-6 sm:p-8 mb-8 ${!isClaimed ? 'opacity-90' : ''}`}>
      <div class="flex items-start gap-4">
        <div class="w-16 h-16 rounded-2xl bg-brand-light flex items-center justify-center flex-shrink-0 text-brand/70">
          <VendorTypeIcon type={vendor.type} size={28} />
        </div>
        <div class="flex-1">
          <div class="flex flex-wrap items-center gap-2 mb-1">
            <h1 class="text-2xl font-bold text-gray-900">{vendor.name}</h1>
            {isClaimed && vendor.tier !== 'free' && (
              <span class="text-xs px-2 py-1 rounded-full bg-brand-accent/10 text-brand-accent font-semibold">
                {vendor.tier === 'pro' ? 'Pro Vendor' : 'Featured Vendor'}
              </span>
            )}
            {!isClaimed && (
              <span class="text-xs px-2 py-1 rounded-full bg-gray-100 text-gray-500 font-medium border border-gray-200">
                Unclaimed listing
              </span>
            )}
          </div>
          <p class="text-gray-500 capitalize text-sm mb-2">{typeLabels[vendor.type] ?? vendor.type}</p>
          {isClaimed && vendor.rating && (
            <p class="text-sm text-gray-600">
              ★ <strong>{vendor.rating}</strong> &nbsp;({vendor.reviewCount} reviews)
            </p>
          )}
        </div>
      </div>

      <p class="mt-5 text-gray-700 leading-relaxed">{vendor.description}</p>

      <!-- Destinations -->
      <div class="mt-5 flex flex-wrap gap-2">
        {vendorDestinations.map(d => (
          <a
            href={`/destinations/${d.slug}/`}
            class="px-3 py-1.5 bg-brand-light rounded-full text-sm text-brand font-medium no-underline hover:bg-brand hover:text-white transition-colors"
          >
            {d.name}
          </a>
        ))}
      </div>

      <!-- CTA: claimed vs unclaimed -->
      <div class="mt-6 pt-6 border-t border-gray-100">
        {isClaimed ? (
          <div class="flex flex-col sm:flex-row gap-3">
            {isLeadVendor && (
              <a href="/quiz/?stage=2" class="btn-primary flex-1 text-center">
                Request a quote →
              </a>
            )}
            {vendor.website && (
              <a
                href={vendor.website}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-outline flex-1 text-center"
              >
                Visit website
              </a>
            )}
          </div>
        ) : (
          <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
            <p class="text-sm font-semibold text-gray-800 mb-1">Is this your business?</p>
            <p class="text-sm text-gray-500 mb-4">
              Claim this free listing to add your photos, control your description, and start
              receiving inquiries from couples planning weddings in {vendorDestinations[0]?.name ?? 'your destination'}.
            </p>
            <a href={claimUrl} class="btn-primary inline-block">
              Claim this listing — it's free →
            </a>
          </div>
        )}
      </div>
    </div>

    <!-- Related vendors -->
    <div class="mt-10">
      <h2 class="text-lg font-bold text-gray-900 mb-4">
        Other vendors in {vendorDestinations[0]?.name ?? 'this destination'}
      </h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {vendors
          .filter(v => v.slug !== vendor.slug && v.destinations.some(d => vendor.destinations.includes(d)))
          .slice(0, 4)
          .map(v => (
            <a href={`/vendors/${v.slug}/`} class="card p-4 hover:shadow-md transition-shadow no-underline group flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-brand-light flex items-center justify-center flex-shrink-0 text-brand/70">
                <VendorTypeIcon type={v.type} size={20} />
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-sm text-gray-900 group-hover:text-brand transition-colors truncate">{v.name}</p>
                <p class="text-xs text-gray-400 capitalize">{typeLabels[v.type] ?? v.type}</p>
              </div>
            </a>
          ))
        }
      </div>
      {vendorDestinations.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1">
          {vendorDestinations.slice(0, 2).map((d: any) => (
            <a
              href={`/vendors/${vendor.type}/${d.slug}/`}
              class="text-brand text-sm font-medium hover:underline no-underline"
            >
              All {typePluralLabels[vendor.type as VendorType]?.toLowerCase() ?? vendor.type} in {d.name} →
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
</BaseLayout>
