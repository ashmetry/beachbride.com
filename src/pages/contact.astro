---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/forms/ContactForm.astro';
---

<PageLayout
  title="Contact BeachBride"
  description="Get in touch with the BeachBride team — corrections, partnerships, or general questions."
  canonical="https://beachbride.com/contact/"
>
  <h1 class="text-3xl font-bold text-gray-900 mb-4">Contact Us</h1>
  <p class="text-gray-600 mb-8">Reach out for content corrections, vendor partnership inquiries, or general questions.</p>

  <ContactForm source="contact" buttonText="Send Message" />
</PageLayout>
