---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="You're All Set | BeachBride"
  description="Your information has been submitted."
  canonical="https://beachbride.com/thank-you/"
  noIndex={true}
>
  <main class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <div class="w-16 h-16 bg-brand/10 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-3">Check your inbox!</h1>
      <p class="text-gray-600 mb-8">
        Your personalized destination guide is on its way. In the meantime, explore our destination guides and vendor directory.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/destinations/" class="btn-secondary">Browse Destinations</a>
        <a href="/blog/" class="btn-outline">Read Our Guides</a>
      </div>
    </div>
  </main>
</BaseLayout>
