---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noIndex?: boolean;
}

const { title, description, canonical, schema, noIndex } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  schema={schema}
  noIndex={noIndex}
>
  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <slot />
  </main>
</BaseLayout>
