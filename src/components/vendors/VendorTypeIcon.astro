---
interface Props {
  type: string;
  class?: string;
  size?: number;
}

const { type, class: className = '', size = 20 } = Astro.props;

// Stroke-based SVG icons — no emojis, renders identically everywhere
const paths: Record<string, string> = {
  photographer: `
    <rect x="3" y="7" width="18" height="13" rx="2" stroke-width="1.5" fill="none"/>
    <circle cx="12" cy="13" r="3" stroke-width="1.5" fill="none"/>
    <path d="M8 7V6a1 1 0 011-1h6a1 1 0 011 1v1" stroke-width="1.5" fill="none"/>
  `,
  planner: `
    <rect x="4" y="4" width="16" height="17" rx="2" stroke-width="1.5" fill="none"/>
    <path d="M9 4V3M15 4V3" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M4 9h16" stroke-width="1.5"/>
    <path d="M8 13h4M8 16h6" stroke-width="1.5" stroke-linecap="round"/>
  `,
  florist: `
    <path d="M12 21V12" stroke-width="1.5" stroke-linecap="round"/>
    <circle cx="12" cy="8" r="3" stroke-width="1.5" fill="none"/>
    <circle cx="7" cy="10" r="2.5" stroke-width="1.5" fill="none"/>
    <circle cx="17" cy="10" r="2.5" stroke-width="1.5" fill="none"/>
    <circle cx="7.5" cy="5.5" r="2" stroke-width="1.5" fill="none"/>
    <circle cx="16.5" cy="5.5" r="2" stroke-width="1.5" fill="none"/>
  `,
  caterer: `
    <path d="M8 3v5a4 4 0 004 4v9" stroke-width="1.5" stroke-linecap="round" fill="none"/>
    <path d="M16 3v18" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M16 8a4 4 0 01-4 4" stroke-width="1.5" fill="none"/>
    <path d="M8 3c0 0 0 2.5 0 5" stroke-width="1.5" stroke-linecap="round"/>
  `,
  dj: `
    <circle cx="12" cy="12" r="9" stroke-width="1.5" fill="none"/>
    <circle cx="12" cy="12" r="3" stroke-width="1.5" fill="none"/>
    <path d="M12 9V3M15 12h6M12 15v6M9 12H3" stroke-width="1.5" stroke-linecap="round"/>
  `,
  officiant: `
    <path d="M12 21C12 21 4 16 4 10a8 8 0 0116 0c0 6-8 11-8 11z" stroke-width="1.5" fill="none"/>
    <circle cx="12" cy="10" r="2.5" stroke-width="1.5" fill="none"/>
  `,
  venue: `
    <path d="M12 3C8 3 5 6 5 9c0 4 7 12 7 12s7-8 7-12c0-3-2.686-6-7-6z" stroke-width="1.5" fill="none"/>
    <path d="M8 9c0 2.21 1.79 4 4 4s4-1.79 4-4" stroke-width="1.5" fill="none"/>
    <path d="M3 21h18" stroke-width="1.5" stroke-linecap="round"/>
  `,
  resort: `
    <rect x="2" y="10" width="20" height="11" rx="1" stroke-width="1.5" fill="none"/>
    <path d="M6 10V6a6 6 0 0112 0v4" stroke-width="1.5" fill="none"/>
    <rect x="9" y="14" width="6" height="7" stroke-width="1.5" fill="none"/>
  `,
  jeweler: `
    <path d="M6 3h12l3 6-9 12L3 9z" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
    <path d="M3 9h18M9 3l-3 6 6 12M15 3l3 6-6 12" stroke-width="1.5" fill="none"/>
  `,
};

const d = paths[type];
---

{d ? (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    stroke="currentColor"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
    aria-hidden="true"
    set:html={d}
  />
) : (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    stroke="currentColor"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class={className}
    aria-hidden="true"
  >
    <rect x="3" y="3" width="18" height="18" rx="3" stroke-width="1.5"/>
    <path d="M9 12h6M12 9v6" stroke-width="1.5" stroke-linecap="round"/>
  </svg>
)}
