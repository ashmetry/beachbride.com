---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 mb-10">
      <!-- Brand -->
      <div class="col-span-2">
        <a href="/" class="flex items-center gap-2 no-underline mb-3">
          <span class="text-xl font-bold text-white">Beach<span class="text-brand-accent font-normal">Bride</span></span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed max-w-xs">
          Expert destination wedding guides and vetted vendor matching for couples planning the perfect beach wedding, anywhere in the world.
        </p>
        <div class="flex gap-4 mt-4">
          <a href="https://instagram.com/beachbride" class="text-gray-400 hover:text-white transition-colors no-underline text-sm">Instagram</a>
          <a href="https://pinterest.com/beachbride" class="text-gray-400 hover:text-white transition-colors no-underline text-sm">Pinterest</a>
        </div>
      </div>

      <!-- Destinations -->
      <div>
        <p class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Destinations</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/destinations/cancun/" class="hover:text-white transition-colors no-underline">Cancun</a></li>
          <li><a href="/destinations/punta-cana/" class="hover:text-white transition-colors no-underline">Punta Cana</a></li>
          <li><a href="/destinations/jamaica/" class="hover:text-white transition-colors no-underline">Jamaica</a></li>
          <li><a href="/destinations/hawaii/" class="hover:text-white transition-colors no-underline">Hawaii</a></li>
          <li><a href="/destinations/bali/" class="hover:text-white transition-colors no-underline">Bali</a></li>
          <li><a href="/destinations/santorini/" class="hover:text-white transition-colors no-underline">Santorini</a></li>
          <li><a href="/destinations/" class="hover:text-white transition-colors no-underline font-medium text-brand-accent">All Destinations →</a></li>
        </ul>
      </div>

      <!-- Plan -->
      <div>
        <p class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Plan</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/quiz/" class="hover:text-white transition-colors no-underline">Get Matched</a></li>
          <li><a href="/vendors/" class="hover:text-white transition-colors no-underline">Find Vendors</a></li>
          <li><a href="/blog/" class="hover:text-white transition-colors no-underline">Wedding Guides</a></li>
          <li><a href="/destination-wedding-cost/" class="hover:text-white transition-colors no-underline">Cost Calculator</a></li>
          <li><a href="/vendors/upgrade/" class="hover:text-white transition-colors no-underline font-medium text-brand-accent">List Your Business</a></li>
          <li><a href="/advertise/" class="hover:text-white transition-colors no-underline font-medium text-brand-accent">Advertise With Us</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <p class="text-sm font-semibold text-white uppercase tracking-wider mb-3">Company</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/about/" class="hover:text-white transition-colors no-underline">About</a></li>
          <li><a href="/contact/" class="hover:text-white transition-colors no-underline">Contact</a></li>
          <li><a href="/privacy-policy/" class="hover:text-white transition-colors no-underline">Privacy</a></li>
          <li><a href="/terms-of-service/" class="hover:text-white transition-colors no-underline">Terms</a></li>
          <li><a href="/disclaimers/" class="hover:text-white transition-colors no-underline">Disclaimers</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <p>&copy; {year} BeachBride.com — All rights reserved.</p>
      <p class="text-center">
        BeachBride is a referral and affiliate service. We may earn a commission on purchases made through links on this site.
      </p>
    </div>
  </div>
</footer>
