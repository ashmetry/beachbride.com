---
/**
 * Ceremony Type Badge — shows whether a destination supports legal,
 * symbolic-recommended, or symbolic-only ceremonies.
 * Replaces the flat amber alert box on destination pages.
 */

interface Props {
  legalCeremonyType: 'legal' | 'symbolic-recommended' | 'symbolic-only';
  legalNotes: string;
  destinationName: string;
}

const { legalCeremonyType, legalNotes, destinationName } = Astro.props;
---

{legalCeremonyType === 'legal' && (
  <div class="bg-green-50 border border-green-200 rounded-xl p-5 text-sm">
    <div class="flex items-start gap-3">
      <span class="text-green-600 text-lg flex-shrink-0">✓</span>
      <div>
        <p class="font-semibold text-green-800 mb-1">Legal ceremony is straightforward</p>
        <p class="text-green-900/80">{legalNotes}</p>
      </div>
    </div>
    <p class="text-xs text-green-700/60 mt-3">Always verify current requirements with local authorities or your wedding planner before finalizing plans.</p>
  </div>
)}

{legalCeremonyType === 'symbolic-recommended' && (
  <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 text-sm">
    <div class="flex items-start gap-3">
      <span class="text-amber-500 text-lg flex-shrink-0">⚠️</span>
      <div>
        <p class="font-semibold text-amber-800 mb-1">Most couples do a symbolic ceremony here</p>
        <p class="text-amber-900/80 mb-3">{legalNotes}</p>
        <a href="/guides/symbolic-ceremony/" class="inline-flex items-center gap-1 text-brand font-semibold hover:underline no-underline">
          Read our Symbolic Ceremony Guide →
        </a>
      </div>
    </div>
    <p class="text-xs text-amber-700/60 mt-3">A symbolic ceremony is just as beautiful — many couples prefer the flexibility it offers.</p>
  </div>
)}

{legalCeremonyType === 'symbolic-only' && (
  <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 text-sm">
    <div class="flex items-start gap-3">
      <span class="text-amber-500 text-lg flex-shrink-0">⚠️</span>
      <div>
        <p class="font-semibold text-amber-800 mb-1">Symbolic ceremony only — legal marriage not available for foreigners</p>
        <p class="text-amber-900/80 mb-3">{legalNotes}</p>
        <div class="bg-white/60 rounded-lg p-3 border border-amber-100">
          <p class="font-semibold text-amber-900 text-xs mb-1">What most couples do:</p>
          <p class="text-amber-800 text-xs">Get legally married at your local courthouse ($50-$100) before or after your trip, then have your dream ceremony in {destinationName}. Your guests won't know the difference — and you'll have complete freedom with venue and officiant.</p>
        </div>
        <a href="/guides/symbolic-ceremony/" class="inline-flex items-center gap-1 text-brand font-semibold hover:underline no-underline mt-3">
          Read our Symbolic Ceremony Guide →
        </a>
      </div>
    </div>
  </div>
)}
