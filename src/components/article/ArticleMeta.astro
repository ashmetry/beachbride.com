---
interface Props {
  publishDate: Date;
  updatedDate?: Date;
  readingTime: number;
}

const { publishDate, updatedDate, readingTime } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<div class="flex flex-wrap items-center gap-3 text-sm text-gray-500 mb-6">
  <time datetime={publishDate.toISOString()}>
    {formatDate(publishDate)}
  </time>
  {updatedDate && (
    <span>
      &middot; Updated <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
    </span>
  )}
  <span>&middot; {readingTime} min read</span>
</div>
