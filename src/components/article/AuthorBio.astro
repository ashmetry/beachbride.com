---
interface Props {
  author?: string;
  reviewer?: string;
}

const { author = 'BeachBride Editorial Team', reviewer } = Astro.props;
---

<div class="mt-12 pt-8 border-t border-gray-200 not-prose">
  <div class="flex items-start gap-4">
    <div class="w-12 h-12 rounded-full bg-brand/10 flex items-center justify-center flex-shrink-0">
      <svg class="w-6 h-6 text-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
    </div>
    <div>
      <p class="font-semibold text-gray-900">
        <a href="/experts/" class="hover:text-brand transition-colors">{author}</a>
      </p>
      <p class="text-sm text-gray-600 mt-0.5 leading-relaxed">
        Our guides are researched and written by BeachBride's in-house team, informed by a network of active wedding photographers and planners working in these destinations.
        <a href="/experts/" class="text-brand hover:text-brand-dark text-xs ml-1 font-medium">Meet our experts →</a>
      </p>
      {reviewer && (
        <p class="text-xs text-gray-400 mt-1.5">Reviewed by {reviewer}</p>
      )}
    </div>
  </div>
</div>
